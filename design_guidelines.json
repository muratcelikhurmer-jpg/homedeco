  "instructions_to_main_agent": [
    "THEME: Implement a 'Luxury Dark' theme. Use #0A0A0A as the base, not pure black.",
    "FONTS: Use 'Playfair Display' for all Headings (H1-H3) and 'Manrope' for Body. Import them from Google Fonts.",
    "COMPONENTS: Use Shadcn UI for the 'Product Configurator' and 'Admin Panel'. Heavily customize them to remove the 'Vercel look'.",
    "MARKETING: Build the Landing Page using raw HTML/Tailwind with the 'Tetris Grid' layout. Do not use Cards here.",
    "AI ASSISTANT: Design the chat interface as a 'Concierge Service'. Use the 'Architect sketching' image as the persona avatar.",
    "CONFIGURATOR: Create a split-screen layout. Left: 3D/Image Preview (Large). Right: Controls (Dense Grid).",
    "TRUST: Use the 'Craftsman' and 'Shipping' images in the 'How it Works' section to emphasize the 'Turkey to Europe' journey.",
    "TESTING: Add data-testid to all interactive elements (buttons, inputs, product cards)."
  ],
  "universal_guidelines": [
    "Avoid generic centered layouts.",
    "Use 2-3x more spacing than typical designs.",
    "Every interaction needs micro-animations.",
    "Use glassmorphism with caution - only for sticky headers or overlays.",
    "Never use default Shadcn colors. Override with the 'Jewel & Luxury' palette."
  ]
