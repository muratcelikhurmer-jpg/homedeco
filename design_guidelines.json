{
  "identity": {
    "name": "E1 - The Anti-AI Designer",
    "mission": "Create a top 1% luxury e-commerce experience that feels like an architectural portfolio, not a template.",
    "principles": [
      "Fusion over Imitation: Mix Architectural Digest aesthetics with SaaS precision.",
      "Emotion First: Trust and Sophistication.",
      "Content is King: Every product photo is a hero.",
      "Zoom In: Focus on textures (wood grain, marble veins).",
      "Negative Space: Luxury needs room to breathe."
    ]
  },
  "typography": {
    "headings": {
      "font_family": "Playfair Display, serif",
      "weights": ["400", "600", "700"],
      "usage": "Main headlines, Section titles, Product names",
      "letter_spacing": "tracking-tight"
    },
    "body": {
      "font_family": "Manrope, sans-serif",
      "weights": ["300", "400", "500", "600"],
      "usage": "Paragraphs, UI elements, Specifications, Prices",
      "letter_spacing": "tracking-normal"
    },
    "mono": {
      "font_family": "JetBrains Mono, monospace",
      "usage": "Order IDs, Dimensions, Technical specs"
    }
  },
  "colors": {
    "palette_name": "Archetype 5: Jewel & Luxury (The 'Obsidian & Gold' Edit)",
    "background": {
      "default": "#0A0A0A",
      "paper": "#121212",
      "subtle": "#1A1A1A"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#A1A1AA",
      "muted": "#52525B"
    },
    "brand": {
      "primary": "#D4AF37",
      "primary_foreground": "#000000",
      "secondary": "#E5E7EB",
      "accent": "#C0C0C0"
    },
    "status": {
      "success": "#10B981",
      "warning": "#F59E0B",
      "error": "#EF4444",
      "info": "#3B82F6"
    }
  },
  "visual_enhancers": {
    "borders": "1px solid rgba(255, 255, 255, 0.08)",
    "glassmorphism": {
      "background": "rgba(18, 18, 18, 0.7)",
      "backdrop_filter": "blur(12px)",
      "border": "1px solid rgba(255, 255, 255, 0.05)"
    },
    "shadows": {
      "card": "0 4px 24px -2px rgba(0, 0, 0, 0.4)",
      "glow": "0 0 20px rgba(212, 175, 55, 0.15)"
    },
    "textures": "Use subtle noise overlays on solid backgrounds to prevent banding and add 'paper' feel."
  },
  "layout_strategies": {
    "marketing": {
      "grid_type": "Mode A: The Tetris Grid",
      "columns": "grid-cols-1 md:grid-cols-12",
      "gap": "gap-8 md:gap-12",
      "rules": "Asymmetry is key. Never fill 100% of the grid. Use empty cells for breathing room."
    },
    "dashboard": {
      "grid_type": "Mode B: High Density Grid",
      "columns": "grid-cols-1 md:grid-cols-4",
      "gap": "gap-4",
      "rules": "Dense, functional. Every pixel utilized. No jagged bottoms."
    }
  },
  "components": {
    "buttons": {
      "primary": "bg-[#D4AF37] text-black hover:bg-[#C5A028] rounded-none uppercase tracking-widest text-xs font-bold px-8 py-4 transition-all duration-300",
      "secondary": "bg-transparent border border-white/20 text-white hover:border-[#D4AF37] hover:text-[#D4AF37] rounded-none uppercase tracking-widest text-xs font-bold px-8 py-4 transition-all duration-300",
      "ghost": "text-white/60 hover:text-white hover:bg-white/5 rounded-none"
    },
    "cards": {
      "style": "bg-[#121212] border border-white/5 hover:border-[#D4AF37]/30 transition-colors duration-300 rounded-none",
      "padding": "p-6 or p-8"
    },
    "inputs": {
      "style": "bg-[#0A0A0A] border-white/10 focus:border-[#D4AF37] rounded-none text-white placeholder:text-white/20 h-12"
    }
  },
